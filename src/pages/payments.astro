---
/**
 * /payments — Digital payment handles (APPROVED users only)
 *
 * Route guard: requireApproved() handles all redirect logic:
 *   - Unauthenticated  → /
 *   - PENDING          → /pending
 *   - DISABLED         → /pending?disabled=1
 *   - APPROVED         → renders this page
 */
import Layout from '../components/Layout.astro';
import AuthNav from '../components/AuthNav.astro';
import { requireApproved } from '../lib/authGuard';

const result = await requireApproved(Astro);
if (result instanceof Response) return result;
const user = result;

const methods = [
  {
    id: 'venmo',
    name: 'Venmo',
    handle: '@BespokeDogAdventures',
    link: 'https://venmo.com/BespokeDogAdventures',
    icon: '💸',
    color: '#3d95ce',
    qr: 'https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=https%3A%2F%2Fvenmo.com%2FBespokeDogAdventures',
    note: 'Tap to pay via Venmo app',
  },
  {
    id: 'cashapp',
    name: 'Cash App',
    handle: '$BespokeDogAdventures',
    link: 'https://cash.app/$BespokeDogAdventures',
    icon: '💵',
    color: '#00d64f',
    qr: 'https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=https%3A%2F%2Fcash.app%2F%24BespokeDogAdventures',
    note: 'Scan or tap to pay via Cash App',
  },
  {
    id: 'paypal',
    name: 'PayPal',
    handle: 'paypal.me/BespokeDogAdventures',
    link: 'https://paypal.me/BespokeDogAdventures',
    icon: '🅿️',
    color: '#003087',
    qr: 'https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=https%3A%2F%2Fpaypal.me%2FBespokeDogAdventures',
    note: 'Pay via PayPal.me link',
  },
  {
    id: 'zelle',
    name: 'Zelle',
    handle: 'hello@dogadventures.example',
    link: null,
    icon: '⚡',
    color: '#6d1ed4',
    qr: null,
    note: "Send to the email above via your bank's Zelle",
  },
];
---
<Layout title="Payments" welcomeName={user.name ?? ''}>
  <Fragment slot="header-action">
    <AuthNav current="payments" />
  </Fragment>

  <h1>Payments</h1>

  <p>
    Choose your preferred payment method below. Scan the QR code or tap the
    handle to open the app directly.
  </p>

  <div class="payment-grid">
    {methods.map((m) => (
      <div class="payment-card">
        <div class="payment-card-header" style={`--brand: ${m.color}`}>
          <span class="payment-icon">{m.icon}</span>
          <span class="payment-name">{m.name}</span>
        </div>

        <div class="payment-card-body">
          {m.qr && (
            <div class="qr-wrap">
              <img
                src={m.qr}
                alt={`QR code for ${m.name}`}
                width="150"
                height="150"
                loading="lazy"
              />
            </div>
          )}

          <div class="payment-details">
            {m.link ? (
              <a class="payment-handle" href={m.link} target="_blank" rel="noopener noreferrer">
                {m.handle}
              </a>
            ) : (
              <span class="payment-handle no-link">{m.handle}</span>
            )}
            <p class="payment-note">{m.note}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="card" style="text-align:center; font-size:0.9rem;">
    <p>
      Questions about payment? Reach out at
      <a href="mailto:hello@dogadventures.example">hello@dogadventures.example</a>.
    </p>
  </div>
</Layout>

<style>
  /* Payment grid */
  .payment-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  /* Card shell */
  .payment-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .payment-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  /* Coloured header band */
  .payment-card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    background: var(--brand);
    color: #fff;
  }

  .payment-icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .payment-name {
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  /* Body */
  .payment-card-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
  }

  /* QR code */
  .qr-wrap {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) - 2px);
    padding: 0.5rem;
    display: inline-flex;
  }

  .qr-wrap img {
    display: block;
    border-radius: 4px;
  }

  /* Handle & note */
  .payment-details {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .payment-handle {
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    word-break: break-all;
  }

  .payment-handle:hover {
    text-decoration: underline;
  }

  .payment-handle.no-link {
    color: var(--color-text);
    cursor: default;
  }

  .payment-note {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    line-height: 1.4;
  }
</style>
