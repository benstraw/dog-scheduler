---
/**
 * /schedule — Google Calendar appointment scheduling (APPROVED users only)
 *
 * Route guard: requireApproved() handles all redirect logic:
 *   - Unauthenticated  → /
 *   - PENDING          → /pending
 *   - DISABLED         → /pending?disabled=1
 *   - APPROVED         → renders this page
 */
import Layout from '../components/Layout.astro';
import LogoutButton from '../components/LogoutButton.astro';
import { requireApproved } from '../lib/authGuard';

const result = await requireApproved(Astro);
if (result instanceof Response) return result;
const user = result;

const embedUrl = import.meta.env.GOOGLE_SCHEDULING_EMBED_URL ?? '';
---
<Layout title="Schedule Your Adventure">
  <Fragment slot="header-action">
    <LogoutButton />
  </Fragment>

  <h1>Schedule Your Dog Adventure</h1>

  {embedUrl ? (
    <>
      <div class="schedule-embed">
        <iframe
          src={embedUrl}
          width="100%"
          height="800"
          style="border:0; display:block;"
          loading="lazy"
          title="Google appointment scheduling"
        ></iframe>
      </div>

      <p style="font-size:0.9rem; text-align:center;">
        Having trouble with the embed?
        <a href={embedUrl} target="_blank" rel="noopener noreferrer">
          Open scheduling page in a new tab ↗
        </a>
      </p>
    </>
  ) : (
    <div class="card">
      <p>
        The scheduling widget is not configured yet. Please set the
        <code>GOOGLE_SCHEDULING_EMBED_URL</code> environment variable.
      </p>
    </div>
  )}

  <p style="font-size:0.85rem; color: var(--color-muted)">
    Logged in{user.name ? ` as ${user.name}` : ''}.
  </p>
</Layout>
