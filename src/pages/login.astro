---
/**
 * /login — Authentication entry point
 *
 * Renders the Descope login widget via the shared DescopeAuth component.
 * Post-login, the client-side JS redirects based on user status.
 */
import Layout from '../components/Layout.astro';
import DescopeAuth from '../components/DescopeAuth.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? Astro.url.origin;
const loginRedirectUrl = new URL('/login', appUrl).href;
---
<Layout title="Log in" showHeader={false}>
  <div style="text-align:center; padding: 1rem 0 1.5rem;">
    <a href="/" style="font-size:1.5rem; text-decoration:none;">Dog Adventures</a>
    <h2 style="margin-top:0.75rem; color: var(--color-muted)">Sign in to continue</h2>
  </div>

  <DescopeAuth heading="Member Login" redirectUrl={loginRedirectUrl} />

  <p style="font-size:0.85rem; text-align:center; color: var(--color-muted)">
    <a href="/">← Back to home</a>
  </p>
</Layout>
