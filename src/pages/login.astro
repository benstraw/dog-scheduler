---
/**
 * /login — Authentication entry point
 *
 * This page serves two purposes:
 *
 * 1. Renders the Descope login widget (Discord OAuth) for unauthenticated users.
 * 2. Acts as the post-login redirect target: the client-side Descope SDK fires
 *    an `onSuccess` event, at which point we POST to /api/auth/session to
 *    exchange the tokens, then redirect to the correct page based on status.
 *
 * No server-side session validation is needed here – the widget handles auth
 * and the client JS below forwards the resulting session token to the server.
 */
import Layout from '../components/Layout.astro';

const projectId = import.meta.env.DESCOPE_PROJECT_ID ?? '';
const missingConfig = !projectId;
---
<Layout title="Log in" showHeader={false}>
  <div style="text-align:center; padding: 1rem 0 1.5rem;">
    <a href="/" style="font-size:1.5rem; text-decoration:none;">🐾 Dog Adventures</a>
    <h2 style="margin-top:0.75rem; color: var(--color-muted)">Sign in to continue</h2>
  </div>

  {missingConfig ? (
    <div class="card" style="text-align:center; color: var(--color-warn)">
      <p>Authentication is not configured yet. Please contact the site owner.</p>
      <p style="font-size:0.8rem; margin-top:0.75rem; opacity:0.75;">
        Site owner: set the <code>DESCOPE_PROJECT_ID</code> environment variable and redeploy.
      </p>
    </div>
  ) : (
    <>
      <!--
        Descope Web Component (web-component SDK).
        The `flow-id` must match the flow configured in your Descope project.
      -->
      <div class="card" style="text-align:center; min-height: 120px; position:relative;" id="widget-container">
        <descope-wc
          project-id={projectId}
          flow-id="sign-up-or-in"
        ></descope-wc>
        <p id="widget-error" style="display:none; color: var(--color-warn); font-family: var(--font-ui); font-size:0.9rem; padding: 1rem 0;">
          Sign-in failed to load. Please <a href="/login">refresh</a> or try again later.
        </p>
      </div>
    </>
  )}

  <p style="font-size:0.85rem; text-align:center; color: var(--color-muted)">
    <a href="/">← Back to home</a>
  </p>
</Layout>

<script>
  // Load the Descope Web Component bundle from the CDN
  const loadWidget = import('https://cdn.jsdelivr.net/npm/@descope/web-component@3/dist/index.js');

  function showError() {
    const widget = document.querySelector('descope-wc') as HTMLElement | null;
    const errEl = document.getElementById('widget-error');
    if (widget) widget.style.display = 'none';
    if (errEl) errEl.style.display = 'block';
  }

  // Show an error if the CDN script fails to load
  loadWidget.catch(() => {
    console.warn('[descope] web-component failed to load from CDN');
    showError();
  });

  // Fallback timeout: if the custom element isn't defined within this time, show an error
  const WIDGET_LOAD_TIMEOUT_MS = 15_000;
  const definedTimeout = setTimeout(() => {
    if (!customElements.get('descope-wc')) showError();
  }, WIDGET_LOAD_TIMEOUT_MS);

  customElements.whenDefined('descope-wc')
    .then(() => clearTimeout(definedTimeout))
    .catch(() => showError());

  // Listen for successful authentication and redirect based on user status
  document.addEventListener('DOMContentLoaded', () => {
    const widget = document.querySelector('descope-wc');
    if (!widget) return;

    widget.addEventListener('success', async (e: Event) => {
      const customEvent = e as CustomEvent<{
        sessionJwt: string;
        user?: { customAttributes?: { status?: string } };
      }>;
      const { sessionJwt, user } = customEvent.detail ?? {};

      // Persist the session token as a cookie so the server can read it
      if (sessionJwt) {
        document.cookie = `DS=${encodeURIComponent(sessionJwt)}; path=/; SameSite=Strict`;
      }

      const status = user?.customAttributes?.status;

      if (status === 'APPROVED') {
        window.location.href = '/schedule';
      } else if (status === 'DISABLED') {
        window.location.href = '/pending?disabled=1';
      } else {
        // PENDING or no status yet — treat as pending
        window.location.href = '/pending';
      }
    });

    // Show an error if the Descope widget fires an error event
    widget.addEventListener('error', () => showError());
  });
</script>
