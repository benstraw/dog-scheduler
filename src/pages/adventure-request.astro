---
/**
 * /adventure-request — Custom adventure request form (APPROVED users only)
 *
 * Route guard: requireApproved() handles all redirect logic:
 *   - Unauthenticated  → /
 *   - PENDING          → /pending
 *   - DISABLED         → /pending?disabled=1
 *   - APPROVED         → renders this page
 */
import Layout from '../components/Layout.astro';
import AuthNav from '../components/AuthNav.astro';
import { requireApproved } from '../lib/authGuard';

const result = await requireApproved(Astro);
if (result instanceof Response) return result;
const user = result;

const formspreeId = import.meta.env.FORMSPREE_ADVENTURE_REQUEST_ID;
const formAction = formspreeId ? `https://formspree.io/f/${formspreeId}` : '';
---
<Layout title="Custom Adventure Request">
  <Fragment slot="header-action">
    <AuthNav current="adventure-request" />
  </Fragment>

  <h1>Custom Adventure Request</h1>

  <p>
    If you would like to go on a truly custom adventure with us just let us know
    and we will do everything we can to accommodate that. Let us know the date
    you want to request and the start time as well as any special requests, like
    multi day, multi dog, etc.
  </p>

  {formAction ? (
  <form
    class="card adventure-request-form"
    method="POST"
    action={formAction}
  >
    <div class="form-group">
      <label for="ar-email">Your Email</label>
      <input
        id="ar-email"
        type="email"
        name="email"
        required
        value={user.email ?? ''}
        autocomplete="email"
      />
    </div>

    <div class="form-group">
      <label for="ar-phone">Phone Number</label>
      <input
        id="ar-phone"
        type="tel"
        name="phone"
        value={user.phone ?? ''}
        autocomplete="tel"
        placeholder="Optional"
      />
    </div>

    <div class="form-group">
      <label for="ar-date">Requested Date &amp; Start Time</label>
      <input
        id="ar-date"
        type="datetime-local"
        name="requested_date"
        required
      />
    </div>

    <div class="form-group">
      <label for="ar-message">Special Requests</label>
      <textarea
        id="ar-message"
        name="message"
        rows="6"
        required
        placeholder="Tell us about your dream adventure — multi-day trips, multiple dogs, specific trails, anything goes!"
      ></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Send Request</button>
  </form>
  ) : (
    <div class="card">
      <p>
        The request form is not configured yet. Please set the
        <code>FORMSPREE_ADVENTURE_REQUEST_ID</code> environment variable.
      </p>
    </div>
  )}
</Layout>

<style>
  .adventure-request-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-group input,
  .form-group textarea {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.6rem 0.85rem;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(74, 124, 89, 0.18);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 140px;
  }

  .btn {
    align-self: flex-start;
  }
</style>
